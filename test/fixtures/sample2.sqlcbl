12097  182-REMOVE-DR-VEH.                                               TJB
12097 *** REMOVE DRIVER TO VEHICLE ASSIGNMENTS FOR DELETED DRIVERS IF   TJB
12097 *** POSSIBLE. GENERATE ERROR IF VEHICLE DRIVER IS PREASSIGNED TO  TJB
12097 *** IS MANUALLY RATED. VEHICLE SHOULD BE CHECKED FOR RERATE.      TJB
12097      MOVE SPACE TO DCPOLITEM.                                     TJB
12097      MOVE A00-M2-POL-NUM OF DCPOLNA                               TJB
12097              TO A00-M4-POL-NUM OF DCPOLITEM.                      TJB
12097      MOVE A30-M2-HIST-EXP-DATE OF DCPOLNA                         TJB
12097              TO A30-M4-HIST-EXP-DATE OF DCPOLITEM.                TJB
12097      MOVE ZERO TO B94-M4-LOCATION OF DCPOLITEM                    TJB
12097                   S06-M4-BUILDING OF DCPOLITEM                    TJB
12097                   B79-M4-ITEM-SEQ OF DCPOLITEM.                   TJB
12097      START FDK04 KEY NOT LESS THAN EXTERNALLY-DESCRIBED-KEY       TJB
12097          INVALID KEY                                              TJB
12097              MOVE ERR-FLAG TO FDK04-STATUS.                       TJB
12097      IF FILESTAT NOT EQUAL "00"                                   TJB
12097          GO TO 182-EXIT                                           TJB
12097      END-IF.                                                      TJB
12097  182-REMOVE-DR-VEH-1.                                             TJB
12097      READ FDK04 NEXT RECORD                                       TJB
12097          AT END                                                   TJB
12097              MOVE ERR-FLAG TO FDK04-STATUS                        TJB
12097      END-READ.                                                    TJB
12097      IF FILESTAT NOT EQUAL "00"                                   TJB
12097          GO TO 182-EXIT                                           TJB
12097      END-IF.                                                      TJB
12097      IF A00-M4-POL-NUM OF DCPOLITEM                               TJB
12097              EQUAL A00-M2-POL-NUM OF DCPOLNA                      TJB
12097          AND A30-M4-HIST-EXP-DATE OF DCPOLITEM                    TJB
12097              EQUAL A30-M2-HIST-EXP-DATE OF DCPOLNA                TJB
12097          NEXT SENTENCE                                            TJB
12097      ELSE                                                         TJB
12097          GO TO 182-EXIT                                           TJB
12097      END-IF.                                                      TJB
12097      IF (A05-M4-SDS-LINE OF DCPOLITEM EQUAL "01" OR "07")         TJB
12097          AND ITEM-MAST-UPD-SW NOT EQUAL "D"                       TJB
12097          AND C75-MDR-ASSIGN OF DCPOLITEM                          TJB
12097              EQUAL B26-M2-NAME-SEQ OF DCPOLNA                     TJB
12097          NEXT SENTENCE                                            TJB
12097      ELSE                                                         TJB
12097          GO TO 182-REMOVE-DR-VEH-1                                TJB
12097      END-IF.                                                      TJB
12097      IF C74-MDR-NUM-IND OF DCPOLITEM EQUAL "Y"                    TJB
12097          AND B81-MRATE-IND OF DCPOLITEM EQUAL "M"                 TJB
12097          MOVE "E" TO ERROR-SWITCH                                 TJB
12097          MOVE IND-ON TO IN29 OF PWK06SUB-O                        TJB
12097                         IN99 OF PWK06DDS-O                        TJB
12097          MOVE "B26" TO ELEMENT-NO, R33-EEM-NUMBER                 TJB
12097          MOVE "06" TO EDIT-NO, R39-EEM-EDIT-NO                    TJB
12097          PERFORM 790-READ-REF-FOR-MESSAGE THRU 790-EXIT           TJB
12097          MOVE ERROR-KEY TO P06-ERR-MESS-NO                        TJB
12097          MOVE HELP-MSG TO P06-ERR-MESSAGE                         TJB
12097          MOVE COL-RESULT TO COP OF PWK06CTL-O                     TJB
12097          MOVE ROW-RESULT TO ROW OF PWK06CTL-O                     TJB
12097          GO TO 182-EXIT                                           TJB
12097      END-IF.                                                      TJB
12097      MOVE SPACE TO C74-MDR-NUM-IND OF DCPOLITEM.                  TJB
12097      MOVE ZERO TO C75-MDR-ASSIGN OF DCPOLITEM.                    TJB
12097      IF B81-MRATE-IND OF DCPOLITEM NOT EQUAL "M"                  TJB
12097          MOVE SPACE TO B83-MCLASS-CODE OF DCPOLITEM               TJB
12097          MOVE ZERO TO Z30-RATING-FACTOR OF DCPOLITEM              TJB
12097      END-IF.                                                      TJB
12097      REWRITE DATA-COLLECT-RECORD-FDK04                            TJB
12097          INVALID KEY                                              TJB
12097              MOVE ERR-FLAG TO FDK04-STATUS                        TJB
12097      END-REWRITE.                                                 TJB
12097      IF FILESTAT EQUAL "00"                                       TJB
12097          GO TO 182-REMOVE-DR-VEH-1                                TJB
12097      END-IF.                                                      TJB

12097  182-EXIT.  EXIT.                                                 TJB
      /***************************************************************
      *                       MAIN PROCESS                           *
      ****************************************************************

       200-MAIN-PROCESS.

           MOVE SPACES TO WS-FEEDBACK.
           MOVE CORR PWK07DDS-O-INDIC TO SAVE-INDICATORS.
           WRITE CRTREC FROM PWK07DDS-O FORMAT IS "PWK07DDS".
           MOVE ZERO TO PWK07DDS-O-INDIC.
           READ SCN INTO PWK07DDS-I FORMAT IS "PWK07DDS".
           MOVE CORR PWK07DDS-I TO PWK07DDS-O.
                                                                        11225JLB
           IF  CFKEY-24
               GO TO 200-EXIT.

           IF  CFKEY-23
               PERFORM 1000-FIND-CURSOR THRU 1000-EXIT
               IF  ERROR-SWITCH EQUAL "E"             AND
                   ROW-RESULT EQUAL ROW OF PWK07DDS-O AND
                   COL-RESULT EQUAL COP OF PWK07DDS-O
                   MOVE "PWK07"            TO R46-HARG-BOOKNO
                   MOVE P07-ERR-MESSAGE    TO HELP-ROW24
                   PERFORM 9005-GET-HELP THRU 9005-EXIT
                   PERFORM 92000-MOVE-FROM-REF THRU 92000-EXIT
                   MOVE CORR SAVE-INDICATORS TO PWK07DDS-O-INDIC
                   GO TO 200-MAIN-PROCESS
               ELSE
                   MOVE SPACES             TO ERROR-SWITCH
                   MOVE IND-OFF            TO IN99 OF PWK07DDS-O
      *            MOVE SPACES             TO P07-ERR-MESSAGE
      *                                       P07-ERR-MESS-NO
                   MOVE "Y"                TO HELP-LOOKUP-SW
                   PERFORM 93000-DETERMINE-POSITION THRU 93010-EXIT
                   IF ALLOW-LOOKUP
                       MOVE "PWK07"        TO R46-HARG-BOOKNO
                       MOVE SPACES         TO HELP-ROW24
                       MOVE "LOOKUP"       TO HELP-MSG
                       PERFORM 9005-GET-HELP THRU 9005-EXIT
                       PERFORM 92000-MOVE-FROM-REF THRU 92000-EXIT
                       MOVE CORR SAVE-INDICATORS TO PWK07DDS-O-INDIC
                       GO TO 200-MAIN-PROCESS
                   ELSE
      *                MOVE CORR SAVE-INDICATORS TO PWK07DDS-O-INDIC
                       GO TO 200-MAIN-PROCESS.

           PERFORM 400-RESET-FACS THRU 400-EXIT.

           MOVE "N" TO EDIT-ERROR-SW.
           IF LS-DETAIL-INQUIRY
               NEXT SENTENCE
           ELSE
               PERFORM 470-EDIT-NAME THRU 585-EXIT.

********** IF CFKEY-2 AND ERROR-ON-EDIT

           IF ERROR-ON-EDIT
               GO TO 200-MAIN-PROCESS.

           IF ENTER-KEY
               GO TO 200-MAIN-PROCESS.

           IF CFKEY-8
               PERFORM 405-DRIVER-ADDR THRU 405-EXIT
                   UNTIL CFKEY-1 OR CFKEY-24 OR CFKEY-3 OR
                         CFKEY-2 AND NO-ERROR-ON-EDIT
               IF CFKEY-3
                   MOVE SPACES TO CFKEY-AREA.

           IF LS-DETAIL-INQUIRY
               NEXT SENTENCE
           ELSE
               IF NO-ERROR-ON-EDIT
                   IF NO-RECORD-FOR-FDK02
                       PERFORM 850-WRITE-NAME-REC THRU 850-EXIT
                   ELSE
                       PERFORM 825-REWRITE-NAME-REC THRU 825-EXIT.

           IF B27-MNAME OF PWK07DDS-I = SPACES
               GO TO 200-EXIT
           ELSE
               MOVE B27-MNAME OF PWK07DDS-I TO P08-NAME.

           IF CFKEY-3
               PERFORM 330-SETUP-DISPLAY THRU 330-EXIT
               IF RECORD-FOUND-ON-FDK03
                   MOVE "CHANGE" TO P08-TRANS
                   PERFORM 320-INQ-TEST THRU 320-EXIT
                   MOVE CORR DCPOLVIOL TO PWK08DDS-O
EY001              PERFORM PROTECT-SYS-UPD THRU
  |                        PROTECT-SYS-UPD-EXIT
  |                IF B72-MDR-CHRG-PA1 = "P"
  |                   MOVE "C" TO B72-MDR-CHARGE1 OF PWK08DDS-O
  |                END-IF
  |                IF B72-MDR-CHRG-PA2 = "P"
  |                   MOVE "C" TO B72-MDR-CHARGE2 OF PWK08DDS-O
  |                END-IF
  |                IF B72-MDR-CHRG-PA3 = "P"
  |                   MOVE "C" TO B72-MDR-CHARGE3 OF PWK08DDS-O
  |                END-IF
  |                IF B72-MDR-CHRG-PA4 = "P"
  |                   MOVE "C" TO B72-MDR-CHARGE4 OF PWK08DDS-O
  |                END-IF
  |                IF B72-MDR-CHRG-PA5 = "P"
  |                   MOVE "C" TO B72-MDR-CHARGE5 OF PWK08DDS-O
  |                END-IF
  |                IF B72-MDR-CHRG-PA6 = "P"
  |                   MOVE "C" TO B72-MDR-CHARGE6 OF PWK08DDS-O
  |                END-IF
  |                IF B72-MDR-CHRG-PA7 = "P"
  |                   MOVE "C" TO B72-MDR-CHARGE7 OF PWK08DDS-O
EY001              END-IF
                   MOVE B64-MVIOL-DATE1 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B64-MVIOL-DATE1 OF PWK08DDS-O
                   MOVE B64-MVIOL-DATE2 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B64-MVIOL-DATE2 OF PWK08DDS-O
                   MOVE B64-MVIOL-DATE3 OF DCPOLVIOL TO RECORD-DATE
