13487      MOVE WORK-DATE-MO                 TO B41-MBIRTH-MO
13487                                                    OF PWK07DDS-O.
13487      MOVE WORK-DATE-DAY                TO B41-MBIRTH-DAY
13487                                                    OF PWK07DDS-O.
13487      ADD  WORK-DATE-CENT    19     GIVING DD8-CENT.
13487      MOVE WORK-DATE-YR                 TO DD8-YY.
13487      MOVE DD8A-CENT-YR                 TO B41-MBIRTH-YR
13487                                                    OF PWK07DDS-O.
           MOVE B51-MLIC-DATE OF DCPOLNA      TO RECORD-DATE.
           MOVE CORR RECORD-DATX TO DISPLAY-DATX.
           MOVE DISPLAY-DATE     TO B51-MLIC-DATE OF PWK07DDS-O.
           MOVE Q74-DR-LIC-EXP-DATE OF DCPOLNA   TO RECORD-DATE.
           MOVE CORR RECORD-DATX TO DISPLAY-DATX.
           MOVE DISPLAY-DATE     TO Q74-DR-LIC-EXP-DATE OF PWK07DDS-O.
           MOVE G39-MFR-EFF-DATE-1 OF DCPOLNA TO RECORD-DATE.
           MOVE CORR RECORD-DATX TO DISPLAY-DATX.
           MOVE DISPLAY-DATE     TO G39-MFR-EFF-DATE-1 OF PWK07DDS-O.
           MOVE G40-MFR-EXP-DATE-1 OF DCPOLNA TO RECORD-DATE.
           MOVE CORR RECORD-DATX TO DISPLAY-DATX.
           MOVE DISPLAY-DATE     TO G40-MFR-EXP-DATE-1 OF PWK07DDS-O.
           MOVE G39-MFR-EFF-DATE-2 OF DCPOLNA TO RECORD-DATE.
           MOVE CORR RECORD-DATX TO DISPLAY-DATX.
           MOVE DISPLAY-DATE     TO G39-MFR-EFF-DATE-2 OF PWK07DDS-O.
           MOVE G40-MFR-EXP-DATE-2 OF DCPOLNA TO RECORD-DATE.
           MOVE CORR RECORD-DATX TO DISPLAY-DATX.
           MOVE DISPLAY-DATE     TO G40-MFR-EXP-DATE-2 OF PWK07DDS-O.
           MOVE Y79-GOOD-STUDENT-DT OF DCPOLNA      TO RECORD-DATE.
           MOVE CORR RECORD-DATX TO DISPLAY-DATX.
           MOVE DISPLAY-DATE     TO Y79-GOOD-STUDENT-DT OF PWK07DDS-O.
14060      MOVE SPACE TO LS-IO-AREA.                                    TJB
14060      MOVE "READ" TO LS-IO-FUNCTION.                               TJB
14060      MOVE "FDK02" TO LS-IO-FILE.                                  TJB
14060      MOVE DATA-COLLECT-RECORD-FDK02 TO LS-IO-RECORD.              TJB
14060      CALL "PRIOC" USING LS-IO-AREA.                               TJB
14060      IF LS-IO-ERROR EQUAL SPACE                                   TJB
14060          MOVE LS-IO-SUPREC TO SAVE-FDK02-SUP                      TJB
14060          MOVE CORR SAV-FDK02-SUPP TO PWK07DDS-O                   TJB
14060          MOVE BA1-MC-LICENSE-DATE OF SAV-FDK02-SUPP TO RECORD-DATETJB
14060          MOVE CORR RECORD-DATX TO DISPLAY-DATX                    TJB
14060          MOVE DISPLAY-DATE TO BA1-MC-LICENSE-DATE OF PWK07DDS-O.  TJB

           MOVE A00-M2-POL-NUM  OF DCPOLNA TO PDA-POLICY OF PWKDADDS-O.
           MOVE P06-TRANS                  TO PDA-TRANS OF PWKDADDS-O.
           MOVE B26-M2-NAME-SEQ OF DCPOLNA TO
                                       PDA-B26-DRIVER OF PWKDADDS-O.
           MOVE B27-MNAME       OF DCPOLNA TO
                                       PDA-B27-NAME1 OF PWKDADDS-O.
           MOVE B28-MNAME-ADDR  OF DCPOLNA TO
                                       PDA-B28-NAME2  OF PWKDADDS-O.
           MOVE B29-MSTREET     OF DCPOLNA TO
                                       PDA-B29-STREET OF PWKDADDS-O.
           MOVE B30-MCITY    OF DCPOLNA TO
                                       PDA-B30-CITY   OF PWKDADDS-O.
           MOVE B31-MST-ABBR OF DCPOLNA TO
                                       PDA-B31-STATE  OF PWKDADDS-O.
           MOVE B32-MZIP1    OF DCPOLNA TO
                                       PDA-B32-ZIP1   OF PWKDADDS-O.
           MOVE B32-MZIP2    OF DCPOLNA TO
                                       PDA-B32-ZIP2   OF PWKDADDS-O.

           IF CFKEY-10  AND NOT  LS-DETAIL-INQUIRY
               MOVE CORR PWK07DDS-O TO PWK07DDS-I
               PERFORM 180-DELETE-DRIVER THRU 180-EXIT
12097          IF ERROR-FOUND                                           TJB
12097              GO TO 100-EXIT                                       TJB
12097          END-IF                                                   TJB
               MOVE IND-ON             TO IN27 OF PWK06CTL-O
               WRITE CRTREC FROM PWK06CTL-O FORMAT "PWK06CTL"
               MOVE ZERO               TO SUBFILE-KEY
               PERFORM 050-LOAD-DRIVERS THRU 050-EXIT
               MOVE IND-OFF            TO IN27 OF PWK06CTL-O
               GO TO 100-EXIT.

           PERFORM 200-MAIN-PROCESS THRU 200-EXIT
                 UNTIL CFKEY-1  OR  CFKEY-24 OR
                       CFKEY-2 AND NO-ERROR-ON-EDIT.

      ****************************************************************
      **      CFKEY-1 FROM SCREEN PWK07                              *
      ****************************************************************

           IF CFKEY-1
              GO TO 100-EXIT
           ELSE
              MOVE SPACES              TO CFKEY-AREA
              MOVE IND-ON              TO IN27 OF PWK06CTL-O
              WRITE CRTREC FROM PWK06CTL-O FORMAT "PWK06CTL"
              MOVE IND-OFF             TO IN27 OF PWK06CTL-O
              MOVE ZERO                TO SUBFILE-KEY
              PERFORM 050-LOAD-DRIVERS THRU 050-EXIT.
       100-EXIT.
           EXIT.
      /
       150-ADD-DRIVER.

12097      MOVE IND-OFF TO IN29 OF PWK06SUB-O                           TJB
12097                      IN33 OF PWK06DDS-O                           TJB
                           IN99 OF PWK06DDS-O.

           MOVE "     ADD"     TO P07-TRANS P08-TRANS.
           READ SCN INTO PWK06DDS-I FORMAT "PWK06DDS".
           MOVE B26-M2-NAME-SEQ OF PWK06DDS-I TO B26-M2-NAME-SEQ
                                             OF DCPOLNA
                                  P07-DRIVER P08-DRIVER.
           MOVE LS-POLICY-NUMBER       TO A00-M2-POL-NUM.
12263      MOVE LS-HISTORY-DATE        TO A30-M2-HIST-EXP-DATE.
           MOVE "DR"                   TO B25-M2-NAME-TYPE.
           PERFORM 815-READ-NAME-REC THRU 815-EXIT.
           IF RECORD-FOUND-ON-FDK02
               MOVE IND-ON             TO IN33 OF PWK06DDS-O
                                          IN99 OF PWK06DDS-O
               MOVE "B26"              TO ELEMENT-NO, R33-EEM-NUMBER
               MOVE "02"               TO EDIT-NO, R39-EEM-EDIT-NO
               PERFORM 790-READ-REF-FOR-MESSAGE THRU 790-EXIT
               MOVE ERROR-KEY          TO P06-ERR-MESS-NO
               MOVE HELP-MSG           TO P06-ERR-MESSAGE
               MOVE 56                 TO COP OF PWK06CTL-O
               MOVE 22                 TO ROW OF PWK06CTL-O
               GO TO 150-EXIT.

           PERFORM 350-INIT THRU 350-EXIT.

      *    DCPOLNA IS INITIALIZED AT THIS POINT; THEREFORE, THIS
      *    MOVE CORRESPONDING WILL INITIALIZE THE SCREEN FORMAT.
           MOVE CORR DCPOLNA           TO PWK07DDS-O.
14060      MOVE CORR SAV-FDK02-SUPP TO PWK07DDS-O.                      TJB
61630      MOVE X71-QUARTER-SECTION(1:1) TO PIP-REJ OF PWK07DDS-O.

           MOVE ZEROS           TO D63-SOC-SEC-NUM OF PWK07DDS-O.
53240      MOVE ZERO TO PASS-SEQ-NUM.
1746       MOVE " "             TO B56-MMVR-IND OF PWK07DDS-O.          11372JLB
1746  *    MOVE "Y"             TO B56-MMVR-IND OF PWK07DDS-O.          11372JLB
           MOVE "N"             TO Q76-LIV-W-SPOUSE-IND OF PWK07DDS-O.

13487      MOVE "mm"            TO B41-MBIRTH-MO  OF PWK07DDS-O.
13487      MOVE "dd"            TO B41-MBIRTH-DAY OF PWK07DDS-O.
13487      MOVE "yyyy"          TO B41-MBIRTH-YR  OF PWK07DDS-O.
13487
           MOVE LS-POLICY-NUMBER           TO PDA-POLICY OF PWKDADDS-O.
           MOVE P07-TRANS                  TO PDA-TRANS  OF PWKDADDS-O.
           MOVE B26-M2-NAME-SEQ OF PWK06DDS-I TO
                                       PDA-B26-DRIVER OF PWKDADDS-O.
           MOVE B28-MNAME-ADDR  OF DCPOLNA TO
                                       PDA-B28-NAME2  OF PWKDADDS-O.
           MOVE B29-MSTREET     OF DCPOLNA TO
                                       PDA-B29-STREET OF PWKDADDS-O.
           MOVE B30-MCITY       OF DCPOLNA TO
                                       PDA-B30-CITY   OF PWKDADDS-O.
           MOVE B31-MST-ABBR    OF DCPOLNA TO
                                       PDA-B31-STATE  OF PWKDADDS-O.
           MOVE B32-MZIP1       OF DCPOLNA TO
                                       PDA-B32-ZIP1   OF PWKDADDS-O.
           MOVE B32-MZIP2       OF DCPOLNA TO
                                       PDA-B32-ZIP2   OF PWKDADDS-O.
           IF B26-M2-NAME-SEQ OF PWK06DDS-I NOT EQUAL ZEROES
               PERFORM 200-MAIN-PROCESS THRU 200-EXIT
                       UNTIL CFKEY-1  OR  CFKEY-24 OR
                             CFKEY-2 AND NO-ERROR-ON-EDIT

           MOVE IND-ON          TO IN27 OF PWK06CTL-O.
           WRITE CRTREC FROM PWK06CTL-O FORMAT "PWK06CTL".
           MOVE IND-OFF         TO IN27 OF PWK06CTL-O.
           MOVE ZERO            TO SUBFILE-KEY.
           PERFORM 050-LOAD-DRIVERS THRU 050-EXIT.

           IF B26-M2-NAME-SEQ OF PWK06DDS-I EQUAL ZEROES
               MOVE IND-ON             TO IN33 OF PWK06DDS-O
                                          IN99 OF PWK06DDS-O
               MOVE "B26"              TO ELEMENT-NO, R33-EEM-NUMBER
               MOVE "04"               TO EDIT-NO, R39-EEM-EDIT-NO
               PERFORM 790-READ-REF-FOR-MESSAGE THRU 790-EXIT
               MOVE ERROR-KEY          TO P06-ERR-MESS-NO
               MOVE HELP-MSG           TO P06-ERR-MESSAGE
               MOVE 56                 TO COP OF PWK06CTL-O
               MOVE 22                 TO ROW OF PWK06CTL-O.

      ****************************************************************
      **          CFKEY-1 FROM PWK07                                 *
      ****************************************************************

               IF CFKEY-1
                  GO TO 150-EXIT
               ELSE
                  MOVE SPACES          TO CFKEY-AREA
                  MOVE IND-ON          TO IN27 OF PWK06CTL-O
                  WRITE CRTREC FROM PWK06CTL-O FORMAT "PWK06CTL"
                  MOVE IND-OFF         TO IN27 OF PWK06CTL-O
                  MOVE ZERO            TO SUBFILE-KEY
                  PERFORM 050-LOAD-DRIVERS THRU 050-EXIT.
                  GO TO 150-EXIT.

       150-EXIT.
           EXIT.

       180-DELETE-DRIVER.
12097      PERFORM 182-REMOVE-DR-VEH THRU 182-EXIT.                     TJB
12097      IF ERROR-FOUND                                               TJB
12097          GO TO 180-EXIT                                           TJB
12097      END-IF.                                                      TJB
14060      IF (SAV-SUP02-UPDSW OF SAVE-FDK02-SUP EQUAL "A"              TJB
14060          AND SAV-SUP02-IND OF SAVE-FDK02-SUP EQUAL "Y")           TJB
