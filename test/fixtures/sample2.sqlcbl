12038          GO TO 181-EXIT                                           TJB
12038      END-IF.                                                      TJB
12038      MOVE LS-POLICY-NUMBER TO A00-M1-POL-NUM.                     TJB
12038      MOVE LS-HISTORY-DATE TO A30-M1-HIST-EXP-DATE.                TJB
12038      READ FDK01                                                   TJB
12038          INVALID KEY                                              TJB
12038              MOVE ERR-FLAG TO FDK01-STATUS.                       TJB
12038      IF FDK01-STATUS EQUAL ZERO                                   TJB
12038          NEXT SENTENCE                                            TJB
12038      ELSE                                                         TJB
12038          GO TO 181-EXIT                                           TJB
12038      END-IF.                                                      TJB
12038      IF WS-SAVE-DATE GREATER THAN Z28-LST-NO-CLM-DR-DATE          TJB
12038          NEXT SENTENCE                                            TJB
12038      ELSE                                                         TJB
12038          GO TO 181-EXIT                                           TJB
12038      END-IF.                                                      TJB
12038      MOVE WS-SAVE-DATE TO Z28-LST-NO-CLM-DR-DATE.                 TJB
12038      REWRITE DATA-COLLECT-RECORD-FDK01                            TJB
12038          INVALID KEY                                              TJB
12038              MOVE ERR-FLAG TO FDK01-STATUS.                       TJB

