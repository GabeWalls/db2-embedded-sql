           IF DATE-RETURN-CODE EQUAL ZERO
               GO TO 745-EDIT-CAUSE.
           MOVE IND-ON TO IN48 OF PWK08DDS-O.
           IF ERROR-ON-EDIT
               GO TO 745-EDIT-CAUSE.
           IF B70-MDR-LOSS-DATE7 OF PWK08DDS-I = ZEROS
               PERFORM 990-B70-07-ERROR THRU 995-EXIT
               GO TO 745-EDIT-CAUSE.
           PERFORM 990-B70-01-ERROR THRU 995-EXIT.

       745-EDIT-CAUSE.

           MOVE "B71" TO R33-EEV-ELEMENT-NUMBER.
           MOVE "03" TO R39-EEV-EDIT-NO.
           MOVE B71-MDR-CAUSE7  OF PWK08DDS-I TO R43-EEV-S-1STVALUE.
           PERFORM 780-READ-REF-TO-EDIT THRU 780-EXIT.
           IF RF-SUCCESSFUL
               GO TO 746-EDIT-AT-FAULT-7.
           MOVE IND-ON TO IN86 OF PWK08DDS-O.
           IF ERROR-ON-EDIT
               GO TO 746-EDIT-AT-FAULT-7.
           PERFORM 969-B71-037-ERROR THRU 995-EXIT.

       746-EDIT-AT-FAULT-7.

           MOVE "B74" TO R33-EEV-ELEMENT-NUMBER.
           MOVE "01" TO R39-EEV-EDIT-NO.
           MOVE B74-MDR-CL-AT-FAULT7 OF PWK08DDS-I
                                          TO R43-EEV-S-1STVALUE.
           PERFORM 780-READ-REF-TO-EDIT THRU 780-EXIT.
           IF RF-SUCCESSFUL
               GO TO 747-EDIT-DR-CHARGE7.
           MOVE IND-ON TO IN49   OF PWK08DDS-O.
           IF ERROR-ON-EDIT
               GO TO 747-EDIT-DR-CHARGE7.
           PERFORM 990-B74-01-ERROR THRU 995-EXIT.

       747-EDIT-DR-CHARGE7.

           MOVE "B72" TO R33-EEV-ELEMENT-NUMBER.
14011      MOVE "04" TO R39-EEV-EDIT-NO.                                TJB
           MOVE B72-MDR-CHARGE7 OF PWK08DDS-I TO R43-EEV-S-1STVALUE.
           PERFORM 780-READ-REF-TO-EDIT THRU 780-EXIT.
           IF RF-SUCCESSFUL
               GO TO 750-EXIT.
           MOVE IND-ON TO IN50   OF PWK08DDS-O.
           IF ERROR-ON-EDIT
               GO TO 750-EXIT.
           IF B72-MDR-CHARGE7 OF PWK08DDS-I = SPACES
               PERFORM 991-B72-03-ERROR THRU 995-EXIT
               GO TO 750-EXIT.
14011      PERFORM 991-B72-04-ERROR THRU 995-EXIT.                      TJB

       750-EXIT.
           EXIT.

       760-SETUP-E04-MNAME-ALPHA.
           MOVE ZERO TO TALLY.
           INSPECT B27-MNAME OF PWK07DDS-I
               TALLYING TALLY FOR ALL "*".
           IF B27-MNAME OF PWK07DDS-I EQUAL
               B27-MNAME OF DCPOLNA AND TALLY EQUAL ZERO
                   GO TO 760-EXIT.
           IF TALLY EQUAL 1
               GO TO 760-EDIT-CHAR-AFTER-ASTERISK
           ELSE
               MOVE IND-ON TO IN30 OF PWK07DDS-O
               IF ERROR-ON-EDIT
                   GO TO 760-EXIT
               ELSE
                   PERFORM 901-B27-04-ERROR THRU 950-EXIT
                   GO TO 760-EXIT.

       760-EDIT-CHAR-AFTER-ASTERISK.
           MOVE ZERO TO TALLY.
           INSPECT B27-MNAME OF PWK07DDS-I
               TALLYING TALLY FOR ALL "* "
           IF TALLY EQUAL ZERO
               PERFORM 770-SETUP-ALTERNATE-KEY THRU 770-EXIT
           ELSE
               MOVE IND-ON TO IN30 OF PWK07DDS-O
               IF ERROR-ON-EDIT
                   GO TO 760-EXIT
               ELSE PERFORM 901-B27-09-ERROR THRU 950-EXIT.

       760-EXIT.
           EXIT.
      /****************************************************************
      *    SET UP NAME FOR ALPHA INDEX
      *****************************************************************

       770-SETUP-ALTERNATE-KEY.

           MOVE B27-MNAME OF PWK07DDS-I  TO ZSHFT-NAME-AREA.

           MOVE 30                       TO LAST-CHAR.
           PERFORM 773-FIND-LAST-POSITION THRU 773-EXIT
               UNTIL ZSHFT-NAME-BYTE (LAST-CHAR) NOT EQUAL SPACE
                  OR LAST-CHAR EQUAL 1.

           ADD 1                         TO LAST-CHAR.
           MOVE ZEROS                    TO ZS-INDX2.

           PERFORM 775-SETUP-E04-FIELD THRU 775-EXIT
               VARYING ZS-INDX1 FROM 1 BY 1
               UNTIL ZS-INDX1 GREATER THAN 30
                  OR ZS-INDX2 GREATER THAN 10.

      **   Z100 IS FOUND IN COPY BOOK ZCB47
      **   REMOVES THE "*" AND SHIFTS THE NAME FIELD ACCORDINGLY
           PERFORM Z100-ZSHFT-ROUTINE THRU Z100-ZSHFT-ROUTINE-EXIT.

           MOVE WS-E04-NAME-AREA TO E04-MNAME-ALPHA OF DCPOLNA.
       770-EXIT.
           EXIT.

       773-FIND-LAST-POSITION.
           SUBTRACT 1 FROM LAST-CHAR.
       773-EXIT.
           EXIT.

       775-SETUP-E04-FIELD.

           IF LAST-CHAR LESS THAN 30 AND
              ZS-INDX1 GREATER THAN LAST-CHAR
               SUBTRACT LAST-CHAR FROM ZS-INDX1.

           IF ZSHFT-NAME-BYTE (ZS-INDX1) NOT EQUAL "*" AND
              ZS-INDX2 EQUAL ZERO
               GO TO 775-EXIT.

           IF ZSHFT-NAME-BYTE (ZS-INDX1) EQUAL "*"
               IF ZS-INDX1 NOT GREATER THAN ZS-INDX2
                   MOVE 11             TO ZS-INDX2
                   GO TO 775-EXIT
               ELSE
                   ADD 1               TO ZS-INDX1
                                          ZS-INDX2.

           MOVE ZSHFT-NAME-BYTE (ZS-INDX1)
                                       TO WS-E04-NAME-BYTE (ZS-INDX2).
           ADD 1                       TO ZS-INDX2.

       775-EXIT.
           EXIT.

      *Z100-ZSHFT-ROUTINE.
       COPY ZCB47.
      *Z100-ZSHFT-ROUTINE-EXIT.
      *    EXIT.

      /***************************************************************
      *    CALL REFERENCE FILE I/O MODULE  TO  EDIT FIELDS.          *
      ****************************************************************

       780-READ-REF-TO-EDIT.

           CALL "ZS001" USING REF-FILE-ARG1
                                EEV-RECORD
                                LINKAGE-ARGUMENTS.

       780-EXIT.
           EXIT.

      ****************************************************************
      *    CALL REFERENCE FILE I/O MODULE TO GET ERROR MESSAGE       *
      ****************************************************************

       790-READ-REF-FOR-MESSAGE.

           CALL "ZS001" USING REF-FILE-ARG1
                                EEM-RECORD
                                LINKAGE-ARGUMENTS.
           IF RF-SUCCESSFUL
               MOVE R41-EEM-MESSAGE TO HELP-MSG
           ELSE
               MOVE "018" TO ELEMENT-NO
               MOVE "IN" TO EDIT-NO
               MOVE "EDIT MESSAGE NOT ON REFERENCE FILE" TO HELP-MSG.

       790-EXIT.
           EXIT.
      /***************************************************************
      *    CALL DATE SUBROUTINE TO VALIDATE DATE EFF & EXP DATES     *
      ****************************************************************

       799-CALL-DATE-SUBROUTINE.

           MOVE ZERO TO DAYS-TO-ADD.
           MOVE DATE-YY-MM-DD TO DATE-TO-ADD-TO.
           MOVE "V" TO DATE-CALL-TYPE.
           CALL "DATECV" USING DATE-CALL-PARAMETERS.

       799-EXIT.
           EXIT.
      /***************************************************************
      *    READ DATA COLLECT NAME RECORD                             *
      ****************************************************************

       815-READ-NAME-REC.
14060      MOVE SPACE TO LS-IO-AREA.                                    TJB
14060      MOVE "READ" TO LS-IO-FUNCTION.                               TJB
14060      MOVE "FDK02" TO LS-IO-FILE.                                  TJB
14060      MOVE DATA-COLLECT-RECORD-FDK02 TO LS-IO-RECORD.              TJB
14060      CALL "PRIOC" USING LS-IO-AREA.                               TJB
14060      IF LS-IO-ERROR NOT EQUAL SPACE                               TJB
14060***THIS SHOULD NEVER HAPPEN, BUT IF IT DOES THIS WILL CAUSE ERROR. TJB
14060          MOVE "0" TO FDK02-STATUS                                 TJB
14060      ELSE                                                         TJB
14060          MOVE LS-IO-SUPREC TO SAVE-FDK02-SUP.                     TJB
           READ FDK02
               INVALID KEY
               MOVE ERR-FLAG TO FDK02-STATUS
               GO TO 815-EXIT.
           MOVE ERR-FLAG TO FDK02-STATUS.

       815-EXIT.
           EXIT.

