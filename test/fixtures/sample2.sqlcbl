                   MOVE DISPLAY-DATE TO B64-MVIOL-DATE3 OF PWK08DDS-O
                   MOVE B64-MVIOL-DATE4 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B64-MVIOL-DATE4 OF PWK08DDS-O
                   MOVE B64-MVIOL-DATE5 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B64-MVIOL-DATE5 OF PWK08DDS-O
                   MOVE B64-MVIOL-DATE6 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B64-MVIOL-DATE6 OF PWK08DDS-O
                   MOVE B64-MVIOL-DATE7 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B64-MVIOL-DATE7 OF PWK08DDS-O
                   MOVE B64-MVIOL-DATE8 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B64-MVIOL-DATE8 OF PWK08DDS-O
                   MOVE B64-MVIOL-DATE9 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B64-MVIOL-DATE9 OF PWK08DDS-O
                   MOVE B70-MDR-LOSS-DATE1 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B70-MDR-LOSS-DATE1 OF PWK08DDS-O
                   MOVE B70-MDR-LOSS-DATE2 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B70-MDR-LOSS-DATE2 OF PWK08DDS-O
                   MOVE B70-MDR-LOSS-DATE3 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B70-MDR-LOSS-DATE3 OF PWK08DDS-O
                   MOVE B70-MDR-LOSS-DATE4 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B70-MDR-LOSS-DATE4 OF PWK08DDS-O
                   MOVE B70-MDR-LOSS-DATE5 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B70-MDR-LOSS-DATE5 OF PWK08DDS-O
                   MOVE B70-MDR-LOSS-DATE6 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B70-MDR-LOSS-DATE6 OF PWK08DDS-O
                   MOVE B70-MDR-LOSS-DATE7 OF DCPOLVIOL TO RECORD-DATE
                   MOVE CORR RECORD-DATX TO DISPLAY-DATX
                   MOVE DISPLAY-DATE TO B70-MDR-LOSS-DATE7 OF PWK08DDS-O
                   MOVE SPACES TO WS-FEEDBACK
                   PERFORM 250-DISPLAY-P08 THRU 250-EXIT
                   UNTIL CFKEY-1  OR  CFKEY-2  OR  CFKEY-24 OR CFKEY-3
                   IF CFKEY-1
                      NEXT SENTENCE
                   ELSE
                       MOVE SPACES TO CFKEY-AREA
               ELSE
                   IF LS-DETAIL-INQUIRY
                       MOVE "NO VIOLATIONS OR LOSSES FOR THIS DRIVER"
                                     TO P07-ERR-MESSAGE
                       MOVE "FP004" TO P07-ERR-MESS-NO
                       MOVE IND-ON TO IN99 OF PWK07DDS-O
                       GO TO 200-MAIN-PROCESS
                   ELSE
                       PERFORM 360-INIT-VIOL THRU 360-EXIT
                       MOVE CORR DCPOLVIOL TO PWK08DDS-O
                       MOVE "   ADD" TO P08-TRANS
                       MOVE SPACES TO WS-FEEDBACK
                       PERFORM 250-DISPLAY-P08 THRU 250-EXIT
                       UNTIL CFKEY-1 OR CFKEY-2 OR CFKEY-24 OR CFKEY-3
                       IF CFKEY-1
                          NEXT SENTENCE
                       ELSE
                          MOVE SPACES TO CFKEY-AREA.

           IF NOT CFKEY-21
               GO TO 200-EXIT.

           IF CFKEY-21                                                  11225JLB
53239          MOVE B49-MLIC-NUM OF PWK07DDS-I TO PASS-LIC-NUM          11225JLB
61780          MOVE B50-MLIC-STATE OF PWK07DDS-I TO PASS-LIC-ST
53239          MOVE ZERO TO PASS-BIRTH-DATE
53239          IF B41-MBIRTH-YR OF PWK07DDS-I(1:2) EQUAL "20"
53239              MOVE 1 TO PASS-BIRTH-DATE(1:1)
53239          END-IF
53239          MOVE B41-MBIRTH-YR OF PWK07DDS-I(3:2)
53239                  TO PASS-BIRTH-DATE(2:2)
53239          MOVE B41-MBIRTH-MO OF PWK07DDS-I
53239                  TO PASS-BIRTH-DATE(4:2)
53239          MOVE B41-MBIRTH-DAY OF PWK07DDS-I
53239                  TO PASS-BIRTH-DATE(6:2)
53239          MOVE B45-MSEX OF PWK07DDS-I TO PASS-SEX
53239          MOVE D63-SOC-SEC-NUM OF PWK07DDS-I TO PASS-SSN
               CALL "PRMV055C" USING PASS-PARMS                         11225JLB
           END-IF.

       200-EXIT.
           EXIT.

      ******************************************************************
      *       DRIVER VIOLATIONS AND CLAIMS ROUTINE                     *
      ******************************************************************

       250-DISPLAY-P08.

EY001      PERFORM PROTECT-SYS-UPD THRU
EY001              PROTECT-SYS-UPD-EXIT.
           MOVE CORR PWK08DDS-O-INDIC TO SAVE-INDICATORS.
           MOVE SPACES TO WS-FEEDBACK.
           WRITE CRTREC FROM PWK08DDS-O FORMAT IS "PWK08DDS".
           MOVE ZERO TO PWK08DDS-O-INDIC.
           READ SCN INTO PWK08DDS-I FORMAT IS "PWK08DDS".
           MOVE CORR PWK08DDS-I TO PWK08DDS-O.

           IF  CFKEY-24
               GO TO 250-EXIT.

           IF CFKEY-23
               PERFORM 1000-FIND-CURSOR THRU 1000-EXIT
               PERFORM 95000-DETERMINE-POSITION THRU 95010-EXIT
               IF ALLOW-LOOKUP
                   MOVE "PWK08"        TO R46-HARG-BOOKNO
                   MOVE SPACES         TO HELP-ROW24
                   MOVE "LOOKUP"       TO HELP-MSG
                   PERFORM 9005-GET-HELP THRU 9005-EXIT
                   PERFORM 94000-MOVE-FROM-REF THRU 94000-EXIT
                   MOVE CORR SAVE-INDICATORS  TO PWK08DDS-O-INDIC
                   GO TO 250-EXIT
               ELSE
      *            MOVE CORR SAVE-INDICATORS  TO PWK08DDS-O-INDIC
                   GO TO 250-EXIT.

           PERFORM 400-RESET-FACS THRU 400-EXIT.
           IF LS-DETAIL-INQUIRY
               GO TO 250-EXIT.
           IF VIOL-UPDATE-SWITCH NOT = "A"
               MOVE "C" TO VIOL-UPDATE-SWITCH.

           MOVE "N" TO EDIT-ERROR-SW.
           PERFORM 590-EDIT-VIOL-DATE1 THRU 750-EXIT.

           IF ERROR-ON-EDIT  OR  ENTER-KEY
                GO TO 250-DISPLAY-P08.

      ******************************************************************
      **   MUST BE CF1, CF2 OR CF3     FROM PWK08                      *
      ******************************************************************

           IF NO-ERROR-ON-EDIT
               MOVE LS-POLICY-NUMBER TO A00-M3-POL-NUM
               MOVE LS-HISTORY-DATE  TO A30-M3-HIST-EXP-DATE
               MOVE "DR" TO B25-M3-NAME-TYPE
               MOVE P07-DRIVER OF PWK07DDS-O TO
                                         B26-M3-NAME-SEQ OF DCPOLVIOL
               PERFORM 870-READ-VIOL-REC THRU 870-EXIT
               IF RECORD-FOUND-ON-FDK03
                   PERFORM 875-REWRITE-VIOL-REC THRU 875-EXIT
               ELSE
                   PERFORM 880-WRITE-VIOL-REC THRU 880-EXIT.

       250-EXIT.
           EXIT.

       300-TERMINATION.
      ******************************************************************
      *                          TERMINATION                           *
      ******************************************************************
           IF CFKEY-1
               MOVE 01 TO LS-CFKEY.
           CLOSE SCN.
12038      CLOSE FDK01                                                  TJB
12038            FDK02                                                  TJB
12038            FDK03                                                  TJB
65423            ZDK01
12038            FDK04.


       300-EXIT.  EXIT.

       320-INQ-TEST.

           IF NOT LS-DETAIL-INQUIRY
               GO TO 320-EXIT.
           IF VIOL-UPDATE-SWITCH = "A"
               MOVE "    ADD" TO P08-TRANS
               GO TO 320-EXIT.
           IF VIOL-UPDATE-SWITCH = "C"
               MOVE " CHANGES" TO P08-TRANS
               GO TO 320-EXIT.
           MOVE SPACES TO P08-TRANS.

       320-EXIT.
           EXIT.

       330-SETUP-DISPLAY.

           MOVE ZERO TO FDK03-STATUS.
           MOVE "Y" TO EDIT-ERROR-SW.
           PERFORM 360-INIT-VIOL THRU 360-EXIT.
           MOVE LS-POLICY-NUMBER TO A00-M3-POL-NUM.
           MOVE LS-HISTORY-DATE  TO A30-M3-HIST-EXP-DATE.
           MOVE "DR" TO B25-M3-NAME-TYPE.
           MOVE P07-DRIVER OF PWK07DDS-O
             TO B26-M3-NAME-SEQ OF DCPOLVIOL.

           START FDK03 KEY NOT < EXTERNALLY-DESCRIBED-KEY
               INVALID KEY
                   MOVE ERR-FLAG TO FDK03-STATUS
                   GO TO 330-EXIT.

           READ FDK03 NEXT
               AT END
                   MOVE ERR-FLAG TO FDK03-STATUS
                   GO TO 330-EXIT.

           IF A00-M3-POL-NUM NOT = LS-POLICY-NUMBER
               OR B25-M3-NAME-TYPE NOT = "DR"
               OR B26-M3-NAME-SEQ OF DCPOLVIOL NOT =
                   P07-DRIVER OF PWK07DDS-O
                       MOVE "2" TO FDK03-STATUS.

       330-EXIT.
           EXIT.
      /***************************************************************
      *            INITIALIZE NAME & ADDRESS REC & VIOL REC          *
      ****************************************************************

       350-INIT.

           PERFORM 025-INIT-FDK02-REC THRU 025-EXIT.

       350-EXIT.
           EXIT.

       360-INIT-VIOL.

           MOVE SPACES TO DATA-COLLECT-RECORD-FDK03.
           COPY PCB50.

       360-EXIT.
           EXIT.
      /***************************************************************
      *    RESET SWITCHES, AND INITIALIZE FIELDS                     *
      ****************************************************************

       400-RESET-FACS.

           MOVE LS-POLICY-NUMBER TO P06-POLICY P07-POLICY P08-POLICY.

           MOVE SPACES TO P07-ERR-MESS-NO P08-ERR-MESS-NO
                          P07-ERR-MESSAGE P08-ERR-MESSAGE
                          ERR-FLAG.

           MOVE "N" TO EDIT-ERROR-SW.

           MOVE ZEROS TO ROW OF PWK07DDS-I
                         ROW OF PWK07DDS-O
                         COP OF PWK07DDS-O
                         ROW OF PWK08DDS-I
                         ROW OF PWK08DDS-O
                         COP OF PWK08DDS-O
                         COP OF PWK07DDS-I
                         COP OF PWK08DDS-I.
           MOVE IND-OFF TO IN69 OF PWK07DDS-O
                           IN70 OF PWK07DDS-O
                           IN71 OF PWK07DDS-O
                           IN72 OF PWK07DDS-O.
           IF LS-DETAIL-INQUIRY
               MOVE 1 TO ROW OF PWK07DDS-O
                         COP OF PWK07DDS-O
                         ROW OF PWK08DDS-O
                         COP OF PWK08DDS-O.

61630      IF LS-A02-STATE NOT EQUAL "KY"
61630         MOVE IND-ON  TO IN56 OF PWK07DDS-O
61630      ELSE
61630         MOVE IND-OFF TO IN56 OF PWK07DDS-O.

       400-EXIT.
           EXIT.

       405-DRIVER-ADDR.
           MOVE B27-MNAME       OF PWK07DDS-I TO
                                       PDA-B27-NAME1  OF PWKDADDS-O.
           MOVE SPACES TO WS-FEEDBACK.
           MOVE CORR PWKDADDS-O-INDIC TO SAVE-INDICATORS.
           WRITE CRTREC FROM PWKDADDS-O FORMAT IS "PWKDADDS".
           MOVE ZERO TO PWKDADDS-O-INDIC.
           READ SCN INTO PWKDADDS-I FORMAT IS "PWKDADDS".
58017                                                                   HTR
58017      IF PDA-B31-STATE OF PWKDADDS-I EQUAL ".."                    HTR
58017          MOVE HIGH-VALUES TO PDA-B31-STATE OF PWKDADDS-I          HTR
58017                              PDA-B32-ZIP1 OF PWKDADDS-I           HTR
58017          MOVE SPACES TO      PDA-B32-ZIP2 OF PWKDADDS-I.          HTR
58017                                                                   HTR
           MOVE CORR PWKDADDS-I TO PWKDADDS-O.

           PERFORM 400-RESET-FACS THRU 400-EXIT.

           IF CFKEY-24 OR CFKEY-1
               GO TO 200-MAIN-PROCESS.

           IF  CFKEY-23
               PERFORM 1000-FIND-CURSOR THRU 1000-EXIT
               IF  ERROR-SWITCH EQUAL "E"             AND
                   ROW-RESULT EQUAL ROW OF PWKDADDS-O AND
                   COL-RESULT EQUAL COP OF PWKDADDS-O
                   MOVE "PWKDA"            TO R46-HARG-BOOKNO
                   MOVE PDA-ERR-MESSAGE    TO HELP-ROW24
                   PERFORM 9005-GET-HELP THRU 9005-EXIT
                   PERFORM 92000-MOVE-FROM-REF THRU 92000-EXIT
                   MOVE CORR SAVE-INDICATORS TO PWKDADDS-O-INDIC
                   GO TO 200-MAIN-PROCESS
               ELSE
                   MOVE SPACES             TO ERROR-SWITCH
                   MOVE IND-OFF            TO IN99 OF PWKDADDS-O
                   MOVE "Y"                TO HELP-LOOKUP-SW
                   PERFORM 93000-DETERMINE-POSITION THRU 93010-EXIT
                   IF ALLOW-LOOKUP
                       MOVE "PWKDA"        TO R46-HARG-BOOKNO
                       MOVE SPACES         TO HELP-ROW24
                       MOVE "LOOKUP"       TO HELP-MSG
                       PERFORM 9005-GET-HELP THRU 9005-EXIT
                       PERFORM 92000-MOVE-FROM-REF THRU 92000-EXIT
                       MOVE CORR SAVE-INDICATORS TO PWKDADDS-O-INDIC
                       GO TO 405-DRIVER-ADDR
                   ELSE
                       GO TO 405-DRIVER-ADDR.

           MOVE SPACES                 TO PDA-ERR-MESS-NO
                                          PDA-ERR-MESSAGE.
           MOVE "N" TO EDIT-ERROR-SW.
           PERFORM 410-EDIT-PWKDA THRU 410-EXIT.

           PERFORM 415-MOVE-PWKDA THRU 415-EXIT.

           IF CFKEY-3 OR CFKEY-2
      *        IF NO-ERROR-ON-EDIT
                   GO TO 405-EXIT.

           GO TO 405-DRIVER-ADDR.
       405-EXIT.
           EXIT.

       410-EDIT-PWKDA.
13253      MOVE PDA-B29-STREET OF PWKDADDS-I TO PASSC-ADDR1.             HTR
58017      IF PDA-B31-STATE OF PWKDADDS-I EQUAL HIGH-VALUES              HTR
58017          GO TO 410-EXIT.                                           HTR
13253      MOVE SPACES TO PASSC-ADDR2.                                   HTR
13253      MOVE PDA-B30-CITY OF PWKDADDS-I TO PASSC-CITY.                HTR
13253      MOVE PDA-B31-STATE OF PWKDADDS-I TO PASSC-STATE.              HTR
13253      MOVE PDA-B32-ZIP1 OF PWKDADDS-I TO PASSC-ZIP1.                HTR
13253      MOVE PDA-B32-ZIP2 OF PWKDADDS-I TO PASSC-ZIP2.                HTR
13253      MOVE LS-ACTIVITY-CODE TO PASSC-IND.                           HTR
13253      CALL "PRNA040L" USING RET-CODE CODE1-PASS-AREA.              HTR
13253      MOVE PASSC-ADDR1 TO PDA-B29-STREET OF PWKDADDS-I,                HTR
13253                         PDA-B29-STREET OF PWKDADDS-O.                HTR
13253      MOVE PASSC-CITY TO PDA-B30-CITY OF PWKDADDS-I,                    HTR
13253                        PDA-B30-CITY OF PWKDADDS-O.                    HTR
13253      MOVE PASSC-STATE TO PDA-B31-STATE OF PWKDADDS-I,                  HTR
13253                         PDA-B31-STATE OF PWKDADDS-O.                  HTR
13253      MOVE PASSC-ZIP1 TO PDA-B32-ZIP1 OF PWKDADDS-I,                    HTR
13253                        PDA-B32-ZIP1 OF PWKDADDS-O.                    HTR
13253      MOVE PASSC-ZIP2 TO PDA-B32-ZIP2 OF PWKDADDS-I,                    HTR
13253                        PDA-B32-ZIP2 OF PWKDADDS-O.                    HTR
13253                                                                   HTR
       410-EXIT.
           EXIT.

       415-MOVE-PWKDA.
           MOVE PDA-B28-NAME2 OF PWKDADDS-O   TO
                           B28-MNAME-ADDR OF DCPOLNA.
           MOVE PDA-B29-STREET  OF PWKDADDS-O TO
                           B29-MSTREET  OF DCPOLNA.
           MOVE PDA-B30-CITY    OF PWKDADDS-O TO
                           B30-MCITY    OF DCPOLNA.
           MOVE PDA-B31-STATE   OF PWKDADDS-O TO
                           B31-MST-ABBR OF DCPOLNA.
           MOVE PDA-B32-ZIP1    OF PWKDADDS-O TO
                           B32-MZIP1    OF DCPOLNA.
           MOVE PDA-B32-ZIP2    OF PWKDADDS-O TO
                           B32-MZIP2    OF DCPOLNA.

       415-EXIT.
           EXIT.
      /
      ****************************************************************
      *    EDIT MODIFIABLE FIELDS    FROM PWK07                      *
      ****************************************************************

       470-EDIT-NAME.

           MOVE SPACE TO WS-E04-NAME-AREA.
           IF B27-MNAME OF PWK07DDS-I NOT = SPACES
               PERFORM 760-SETUP-E04-MNAME-ALPHA THRU 760-EXIT
               GO TO 471-DUPLICATE-DRIVER-EDIT.
           MOVE IND-ON TO IN30 OF PWK07DDS-O.
           IF ERROR-ON-EDIT
               GO TO 471-DUPLICATE-DRIVER-EDIT.
           PERFORM 901-B27-01-ERROR THRU 950-EXIT.

65413  471-DUPLICATE-DRIVER-EDIT.
65413      IF (B41-MBIRTH-YR OF PWK07DDS-I = ZERO OR space) OR
65413         (B41-MBIRTH-MO OF PWK07DDS-I = ZERO OR SPACE) OR
65413         (B41-MBIRTH-DAY OF PWK07DDS-I = ZERO OR SPACE)
65413          GO TO 475-EDIT-SOC-SEC.
65413
65413      MOVE ZERO TO WS-SQL-COUNT.
65413
65413      MOVE B41-MBIRTH-YR OF PWK07DDS-I TO WS-DATE-CONVERT(1:4).
65413      MOVE B41-MBIRTH-MO OF PWK07DDS-I TO WS-DATE-CONVERT(5:2).
65413      MOVE B41-MBIRTH-DAY OF PWK07DDS-I TO WS-DATE-CONVERT(7:2).
65413
65413      IF WS-DATE-CONVERT NOT NUMERIC
65413          GO TO 475-EDIT-SOC-SEC.
65413
65413      SUBTRACT 19000000 FROM WS-DATE-CONVERT GIVING
65413                                                  WS-CONVERTED-DOB.
65413      MOVE WS-CONVERTED-DOB TO WS-SQL-ND-DOB.
65413      MOVE 0 TO WS-SQL-COUNT-PLUS1,
65413                TALLY2.
65413      INSPECT B27-MNAME OF PWK07DDS-I TALLYING TALLY2 FOR ALL "*".
65413      IF TALLY2 > 0
65413       MOVE B27-MNAME       OF PWK07DDS-I TO WS-NAME-WITH-ASTERISK
65413       MOVE 1 TO X2
65413       MOVE 1 TO WS-SQL-COUNT-PLUS1
65413 *remove asterisk from b27 of pwk07dds and load into WS-SQL-ND-NAME
65413      PERFORM 95030-REMOVE-ASTERISK THRU 95030-EXIT
65413          varying x1 from 1 by 1
65413          UNTIL X1 greater than 29
65413      ELSE
65413       MOVE B27-MNAME OF PWK07DDS-I TO WS-NAME-WITHOUT-ASTERISK.
65413      MOVE WS-NAME-WITHOUT-ASTERISK TO WS-SQL-ND-NAME.
65413      MOVE LS-POLICY-NUMBER TO WS-SQL-POLICY.
65413
65413      EXEC SQL
65413        SELECT COUNT(*) INTO :WS-SQL-COUNT
65413            FROM FDK02
65413                WHERE FDK02.A00_M2_POL_NUM   = :WS-SQL-POLICY
65413                 AND  FDK02.B25_M2_NAME_TYPE = "DR"
65413                 AND  FDK02.B27_MNAME        = :WS-SQL-ND-NAME
65413                 AND  FDK02.B41_MBIRTH_DATE  = :WS-SQL-ND-DOB
65413                 AND  FDK02.A30_M2_HIST_EXP_DATE = 9999999
65413      END-EXEC.
65413
65413      EVALUATE TRUE
65413          WHEN SQL-SUCCESS
65413              ADD WS-SQL-COUNT-PLUS1 TO WS-SQL-COUNT
65413              IF WS-SQL-COUNT > 1
65413                  MOVE IND-ON TO IN30 OF PWK07DDS-O
65413                  PERFORM 903-B27-14-ERROR THRU 950-EXIT
65413              ELSE
65413                  GO TO 475-EDIT-SOC-SEC
65413              END-IF
65413          WHEN OTHER
65413              GO TO 475-EDIT-SOC-SEC
65413          END-EVALUATE.
65413

65423  475-EDIT-SOC-SEC.
65423
65423      IF D63-SOC-SEC-NUM OF PWK07DDS-O = "666666666"
65423          CALL "PIN" USING D63-SOC-SEC-NUM OF PWK07DDS-I
65423      END-IF

65423      IF Q77-REL-TO-INS-IND OF PWK07DDS-I NOT = "P"
65423         AND Q77-REL-TO-INS-IND OF PWK07DDS-I NOT = "H"
65423           GO TO 480-EDIT-SEX
65423      END-IF

65423      INITIALIZE EEV-RECORD
65423      MOVE "EEV"              TO R01-EEV-TABLEID
65423      MOVE "D63"              TO R33-EEV-ELEMENT-NUMBER
65423      MOVE "13"               TO R39-EEV-EDIT-NO
65423      MOVE D63-SOC-SEC-NUM OF PWK07DDS-O TO EEV-RESTOF-KEY
65423      MOVE EEV-RECORD         TO REF-RECORD

65423      READ ZDK01 INTO EEV-RECORD
65423          INVALID KEY
65423               MOVE FILESTAT TO RF-RETURN-CODE
65423          NOT INVALID KEY
65423               MOVE IND-ON TO IN29 OF PWK07DDS-O
65423               PERFORM 901-D63-05-ERROR THRU 950-EXIT
65423      END-READ.

       480-EDIT-SEX.

           MOVE "B45" TO R33-EEV-ELEMENT-NUMBER.
           MOVE "01" TO R39-EEV-EDIT-NO.
           MOVE B45-MSEX OF PWK07DDS-I TO R43-EEV-S-1STVALUE.
           PERFORM 780-READ-REF-TO-EDIT THRU 780-EXIT.
           IF RF-SUCCESSFUL
               GO TO 500-EDIT-MARITAL-STATUS.
           MOVE IND-ON TO IN31 OF PWK07DDS-O.
           IF ERROR-ON-EDIT
               GO TO 500-EDIT-MARITAL-STATUS.
           PERFORM 902-B45-01-ERROR THRU 950-EXIT.

       500-EDIT-MARITAL-STATUS.

           MOVE "B44" TO R33-EEV-ELEMENT-NUMBER.
           MOVE "01" TO R39-EEV-EDIT-NO.
           MOVE B44-MMARITAL OF PWK07DDS-I TO R43-EEV-T-1STVALUE.
           PERFORM 780-READ-REF-TO-EDIT THRU 780-EXIT.
           IF RF-SUCCESSFUL
               GO TO 508-EDIT-MVR-CODE.
           MOVE IND-ON TO IN32 OF PWK07DDS-O.
           IF ERROR-ON-EDIT
               GO TO 508-EDIT-MVR-CODE.
           PERFORM 904-B44-01-ERROR THRU 950-EXIT.

       508-EDIT-MVR-CODE.

           MOVE "B56" TO R33-EEV-ELEMENT-NUMBER.
           MOVE "01" TO R39-EEV-EDIT-NO.
           MOVE B56-MMVR-IND OF PWK07DDS-I TO R43-EEV-T-1STVALUE.
           PERFORM 780-READ-REF-TO-EDIT THRU 780-EXIT.
           IF RF-SUCCESSFUL
               GO TO 509-EDIT-MVR-DATE.
           MOVE IND-ON TO IN41 OF PWK07DDS-O.
           IF ERROR-ON-EDIT
               GO TO 509-EDIT-MVR-DATE.
           PERFORM 905-B56-01-ERROR THRU 950-EXIT.

       509-EDIT-MVR-DATE.
           IF B57-MMVR-DATE OF PWK07DDS-I EQUAL ZEROES
               GO TO 509-EDIT-MVR-IND.

           MOVE B57-MMVR-DATE OF PWK07DDS-I TO DATEIN.
           MOVE MONTH-DIGITS TO DATE-MM.
61755      IF (MONTH-DIGITS EQUAL 02
61755         AND DAY-DIGITS EQUAL 29)
61755         MOVE 28 TO DAY-DIGITS.
           MOVE DAY-DIGITS TO DATE-DD.
           MOVE YEAR-DIGITS TO DATE-YY.
           PERFORM 799-CALL-DATE-SUBROUTINE THRU 799-EXIT.
           IF DATE-RETURN-CODE EQUAL ZERO
               GO TO 509-EDIT-MVR-IND.
           MOVE IND-ON TO IN28 OF PWK07DDS-O.
           IF ERROR-ON-EDIT
               GO TO 509-EDIT-MVR-IND.
           PERFORM 905-B57-01-ERROR THRU 950-EXIT.

       509-EDIT-MVR-IND.
           IF B56-MMVR-IND OF PWK07DDS-I NOT EQUAL "Y"
               GO TO 510-EDIT-BIRTH-DATE.

           MOVE D63-IRS-NUM-1 OF DCPOLNA TO WS-D63-IRS-NUM-1.
           MOVE D63-IRS-NUM-2 OF DCPOLNA TO WS-D63-IRS-NUM-2.
           MOVE D63-IRS-NUM-3 OF DCPOLNA TO WS-D63-IRS-NUM-3.
*****      IF WS-D63-SOC-SEC-NUM NUMERIC                                TJB
*****          NEXT SENTENCE                                            TJB
*****      ELSE                                                         TJB
*****          MOVE ZERO TO WS-D63-SOC-SEC-NUM.                         TJB

           IF B57-MMVR-DATE OF PWK07DDS-I EQUAL ZEROS
               GO TO 510-EDIT-BIRTH-DATE.

12611      IF LS-COMPANY EQUAL "05"                                     TJB
               MOVE 60 TO DAYS-TO-ADD
           ELSE
               MOVE 150 TO DAYS-TO-ADD.

           MOVE B57-MMVR-DATE OF DCPOLNA TO DATE-TO-ADD-TO.
           PERFORM 2000-CALCULATE-DAYS THRU 2000-EXIT.

           IF  ((SYSTEM-DATE LESS THAN DATE-TO-ADD-TO)
              AND (D63-SOC-SEC-NUM OF PWK07DDS-I EQUAL                  11372161
                  WS-D63-SOC-SEC-NUM)
              AND (B49-MLIC-NUM OF PWK07DDS-I EQUAL
                   B49-MLIC-NUM OF DCPOLNA))
              PERFORM 905-B56-02-ERROR THRU 950-EXIT
           END-IF.

       510-EDIT-BIRTH-DATE.

14537      MOVE B41-MBIRTH-MO OF PWK07DDS-I TO DD8A-MM
14537                                          WS-MMDD(1:2).
14537      MOVE B41-MBIRTH-DAY OF PWK07DDS-I TO DD8A-DD
14537                                           WS-MMDD(3:2).
13487      MOVE B41-MBIRTH-YR   OF PWK07DDS-I TO DD8A-CENT-YR.
13487      IF DISPLAY-DATE8 NOT NUMERIC
13487          MOVE 3                         TO DATE-RETURN-CODE
13487      ELSE IF DD8-CENT EQUAL 19 OR 20
13487          MOVE DD8-MM                    TO DATE-MM
13487          MOVE DD8-DD                    TO DATE-DD
13487          MOVE DD8-YY                    TO DATE-YY
13487          PERFORM 799-CALL-DATE-SUBROUTINE THRU 799-EXIT
13487      ELSE MOVE 1                        TO DATE-RETURN-CODE.
           IF DATE-RETURN-CODE EQUAL ZERO
13487          GO TO 511-EDIT-DRIVER-AGE.
           MOVE IND-ON TO IN33 OF PWK07DDS-O.
           IF ERROR-ON-EDIT
               GO TO 512-EDIT-PRIN-OPER.
13487      IF DATE-RETURN-CODE EQUAL 3
13487          OR DATE-YY-MM-DD EQUAL ZEROES
13487              PERFORM 905-B41-02-ERROR THRU 950-EXIT
13487              GO TO 512-EDIT-PRIN-OPER.
           PERFORM 905-B41-01-ERROR THRU 950-EXIT.
13487      GO TO 512-EDIT-PRIN-OPER.
13487
13487 *NOTE: IGNORE DRIVER AGE EDIT IF BIRTH DATE IS INVALID
13487
13487    511-EDIT-DRIVER-AGE.                                           11524372
13487
13419      MOVE LS-A08-EFF-DATE          TO WORK-DATE.                  11524372

13487      IF B51-MLIC-DATE OF PWK07DDS-I NOT EQUAL ZERO                11372TJB
13487          MOVE B51-MLIC-DATE OF PWK07DDS-I TO DATEIN               11372TJB
13487          MOVE MONTH-DIGITS TO WORK-DATE1-MO                       11372TJB
13487          MOVE DAY-DIGITS TO WORK-DATE1-DAY                        11372TJB
13487          MOVE YEAR-DIGITS TO WORK-DATE1-YR                        11372TJB
13419          PERFORM 95025-CK-WORK1-CENTURY
13419          MOVE LS-A09-EXP-DATE      TO WORK-DATE2                  11372TJB
13487          IF (WORK-DATE1 GREATER THAN WORK-DATE                    11372TJB
13487              AND WORK-DATE1 NOT GREATER THAN WORK-DATE2)          11372TJB
13487              MOVE WORK-DATE1 TO WORK-DATE.                        11372TJB
13487
