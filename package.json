{
  "name": "db2-embedded-sql-cobol",
  "displayName": "DB2 Embedded SQL (COBOL)",
  "description": "DB2 EXEC SQL … END-EXEC highlighting: injects into common COBOL grammars; standalone mode for .sqlcbl/.sqb.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "db2-cobol",
        "aliases": ["DB2 COBOL", "db2-cobol"],
        "extensions": [".sqlcbl", ".sqb"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "db2-cobol",
        "scopeName": "source.db2-cobol",
        "path": "./syntaxes/db2-cobol.tmLanguage.json"
      },
      {
        "scopeName": "source.db2-sql-injection.cobol",
        "path": "./syntaxes/db2-sql-injection.tmLanguage.json",
        "injectTo": ["source.cobol", "source.cobol85", "source.gnucobol"]
      }
    ]
  }
}
