{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DB2 COBOL",
  "scopeName": "source.db2-cobol",
  "patterns": [
    { "include": "#exec-sql-block" },
    { "include": "#cobol-comment" },
    { "include": "#cobol-division-section" },
    { "include": "#cobol-program-id" },
    { "include": "#cobol-paragraph" },
    { "include": "#cobol-level-number" },
    { "include": "#cobol-figurative-constant" },
    { "include": "#cobol-numeric-literal" },
    { "include": "#string-single" },
    { "include": "#string-double" },
    { "include": "#cobol-storage-type" },
    { "include": "#cobol-storage-modifier" },
    { "include": "#cobol-verb" },
    { "include": "#cobol-operator-word" },
    { "include": "#cobol-other-reserved" }
  ],
  "repository": {
    "cobol-comment": {
      "patterns": [
        {
          "name": "comment.line.cobol",
          "match": "(?m)^.{6}[/*][^\\n]*$"
        },
        {
          "name": "comment.line.cobol",
          "match": "(?m)^\\s*\\*>[^\\n]*$"
        }
      ]
    },
    "cobol-division-section": {
      "patterns": [
        {
          "match": "(?i)\\b(IDENTIFICATION|ENVIRONMENT|DATA|PROCEDURE)\\s+(DIVISION)\\b",
          "captures": {
            "1": { "name": "entity.name.division.cobol" },
            "2": { "name": "keyword.declaration.cobol" }
          }
        },
        {
          "match": "(?i)\\b(WORKING-STORAGE|LINKAGE|FILE|LOCAL-STORAGE|COMMUNICATION|REPORT|INPUT-OUTPUT|CONFIGURATION)\\s+(SECTION)\\b",
          "captures": {
            "1": { "name": "entity.name.section.cobol" },
            "2": { "name": "keyword.declaration.cobol" }
          }
        }
      ]
    },
    "cobol-program-id": {
      "match": "(?i)\\b(PROGRAM-ID)(\\.)\\s*([A-Z0-9-]+)?",
      "captures": {
        "1": { "name": "keyword.declaration.cobol" },
        "2": { "name": "punctuation.separator.statement.cobol" },
        "3": { "name": "entity.name.program.cobol" }
      }
    },
    "cobol-paragraph": {
      "patterns": [
        {
          "match": "(?m)^\\s*(\\d{3}-[A-Z0-9]+(?:-[A-Z0-9]+)*)\\.(?=\\s*$)",
          "captures": {
            "1": { "name": "entity.name.section.cobol" }
          }
        },
        {
          "match": "(?m)^\\s*(?!END-|ELSE-|IDENTIFICATION|ENVIRONMENT|DATA|PROCEDURE|WORKING-STORAGE|LINKAGE|FILE|LOCAL-STORAGE|COMMUNICATION|REPORT|INPUT-OUTPUT|CONFIGURATION|PROGRAM-ID|SECTION|DIVISION)([A-Z][A-Z0-9-]{2,})\\.(?=\\s*$)",
          "captures": {
            "1": { "name": "entity.name.function.cobol" }
          }
        }
      ]
    },
    "cobol-level-number": {
      "match": "(?m)^\\s*((?:0[1-9]|[1-4][0-9]|66|77|88))(?=\\s+)",
      "captures": {
        "1": { "name": "constant.numeric.level.cobol" }
      }
    },
    "cobol-figurative-constant": {
      "match": "(?i)\\b(SPACES|SPACE|ZEROS|ZEROES|ZERO|LOW-VALUES|LOW-VALUE|HIGH-VALUES|HIGH-VALUE|NULLS|QUOTE|QUOTES)\\b",
      "captures": {
        "0": { "name": "constant.language.cobol" }
      }
    },
    "cobol-numeric-literal": {
      "patterns": [
        {
          "match": "(?i)(?<![A-Z0-9_])([+-]?\\d+\\.\\d+)(?![A-Z0-9_])",
          "captures": {
            "1": { "name": "constant.numeric.cobol" }
          }
        },
        {
          "match": "(?i)(?<![A-Z0-9_:])\\b(?!0[1-9]|[1-3][0-9]|4[0-9]|66|77|88)([+-]?\\d+)\\b(?!\\()",
          "captures": {
            "1": { "name": "constant.numeric.cobol" }
          }
        }
      ]
    },
    "string-single": {
      "name": "string.quoted.single.cobol",
      "match": "(?m)'(?:''|[^'\\n])*'"
    },
    "string-double": {
      "name": "string.quoted.double.cobol",
      "match": "(?m)\"(?:\"\"|[^\"\\n])*\""
    },
    "cobol-storage-type": {
      "match": "(?i)\\b(PIC|PICTURE|COMP|COMP-1|COMP-2|COMP-3|COMP-4|COMP-5|COMPUTATIONAL|COMPUTATIONAL-1|COMPUTATIONAL-2|COMPUTATIONAL-3|BINARY|PACKED-DECIMAL|ZONED|DISPLAY-1|NATIONAL|BIT|POINTER|PROCEDURE-POINTER|FUNCTION-POINTER|INDEX)\\b",
      "captures": {
        "0": { "name": "storage.type.cobol" }
      }
    },
    "cobol-storage-modifier": {
      "match": "(?i)\\b(OCCURS|REDEFINES|VALUE|VALUES|SIGN|SYNC|SYNCHRONIZED|JUSTIFIED|JUST|USAGE|EXTERNAL|GLOBAL|CONSTANT|VARYING|RENAMES|BLANK|ZERO|REVERSE|DYNAMIC|LENGTH|DEPENDING|ASCENDING|DESCENDING|KEY|INDEXED|RELATIVE|BLOCK|RECORD|LABEL|STANDARD|OMITTED|TRAILING|LEADING|RIGHT|LEFT|CHARACTER|CHARACTERS)\\b",
      "captures": {
        "0": { "name": "storage.modifier.cobol" }
      }
    },
    "cobol-verb": {
      "match": "(?i)\\b(?:ACCEPT|ADD|ALTER|CALL|CANCEL|CLOSE|COMPUTE|CONTINUE|DELETE|DISPLAY|DIVIDE|ENABLE|END-ACCEPT|END-ADD|END-CALL|END-COMPUTE|END-DELETE|END-DIVIDE|END-EVALUATE|END-IF|END-MULTIPLY|END-OF-PAGE|END-PERFORM|END-READ|END-RECEIVE|END-RETURN|END-REWRITE|END-SEARCH|END-START|END-STRING|END-SUBTRACT|END-UNSTRING|END-WRITE|ENTRY|EVALUATE|EXIT|GENERATE|GOBACK|GO\\s+TO|IF|INITIALIZE|INITIATE|INSPECT|MERGE|MULTIPLY|OPEN|PERFORM|PURGE|READ|RECEIVE|RELEASE|RESET|RETURN|REWRITE|SEARCH|SEND|SET|SORT|START|STOP|STRING|SUBTRACT|TERMINATE|UNSTRING|WRITE|UNLOCK|USE)(?!-)\\b",
      "captures": {
        "0": { "name": "keyword.control.cobol" }
      }
    },
    "cobol-operator-word": {
      "match": "(?i)\\b(AND|OR|NOT|EQUAL|THAN|GREATER|LESS|TRUE|FALSE)\\b",
      "captures": {
        "0": { "name": "keyword.operator.cobol" }
      }
    },
    "cobol-other-reserved": {
      "match": "(?i)\\b(?:ADDRESS|ADVANCING|AFTER|ALL|ALPHABET|ALPHABETIC|ALPHABETIC-LOWER|ALPHABETIC-UPPER|ALPHANUMERIC|ALPHANUMERIC-EDITED|ALSO|ALTERNATE|ANY|ARE|AREA|AREAS|ASSIGN|AT|AUTHOR|BEFORE|BOTTOM|BY|CBL|CD|CF|CH|CLASS|CODE|CODE-SET|COLLATING|COLUMN|COMMA|COMMON|COMMUNICATION|CONFIGURATION|CONTENT|CONTROL|CONTROLS|CONVERTING|COPY|CORR|CORRESPONDING|COUNT|CURRENCY|DATE|DATE-COMPILED|DAY|DAY-OF-WEEK|DBCS|DE|DEBUGGING|DECLARATIVES|DELIMITED|DELIMITER|DESTINATION|DETAIL|DOWN|DUPLICATES|EGI|EJECT|ELSE|EMI|END|ENTER|ENVIRONMENT|EOP|ERROR|ESI|EVERY|EXCEPTION|EXTEND|FD|FILLER|FINAL|FIRST|FOOTING|FOR|FROM|FUNCTION|GIVING|GROUP|HEADING|I-O|I-O-CONTROL|IN|INDEX|INDICATE|INPUT|INPUT-OUTPUT|INSTALLATION|INTO|INVALID|LABEL|LAST|LINAGE|LINAGE-COUNTER|LINE|LINE-COUNTER|LINES|LOCK|MEMORY|MESSAGE|MODE|MODULES|MULTIPLE|NATIVE|NEXT|NO|NUMBER|NUMERIC|NUMERIC-EDITED|OBJECT-COMPUTER|OF|OFF|ON|OPTIONAL|ORGANIZATION|OTHER|OUTPUT|OVERFLOW|OWN|PADDING|PAGE|PAGE-COUNTER|PF|PH|PLUS|POSITION|PRINTING|PROCEDURE|PROCEDURES|PROCEED|QUEUE|RANDOM|RD|RECORD|RECORDING|RECORDS|REEL|REFERENCE|REFERENCES|REMAINDER|REMOVAL|REPLACE|REPLACING|REPORT|REPORTING|REPORTS|RERUN|RESERVE|RETURNING|REVERSED|REWIND|RF|RH|RUN|SAME|SD|SECURITY|SEGMENT|SEGMENT-LIMIT|SELECT|SENTENCE|SEPARATE|SEQUENCE|SEQUENTIAL|SIZE|SORT-MERGE|SOURCE|SOURCE-COMPUTER|SPECIAL-NAMES|STANDARD|STANDARD-1|STANDARD-2|STATUS|SUB-QUEUE-1|SUB-QUEUE-2|SUB-QUEUE-3|SUM|SUPPRESS|SYMBOLIC|TABLE|TALLYING|TAPE|TERMINAL|TEST|THROUGH|THRU|TIME|TIMES|TO|TOP|TYPE|UNIT|UNTIL|UP|UPON|USING|WHEN|WITH|WORDS)\\b",
      "captures": {
        "0": { "name": "keyword.other.cobol" }
      }
    },
    "sql-function": {
      "name": "support.function.sql",
      "match": "(?i)\\b(COUNT|SUM|AVG|MIN|MAX|SUBSTR|SUBSTRING|LENGTH|CHAR|VARCHAR|TRIM|LTRIM|RTRIM|COALESCE|NULLIF|CAST|CONVERT|DIGITS|DECIMAL|FLOAT|INTEGER|SMALLINT|CHAR_LENGTH|POSITION|CONCAT|UCASE|LCASE|UPPER|LOWER|YEAR|MONTH|DAY|DATE|TIME|TIMESTAMP|ROWNUMBER|RANK|DENSE_RANK)\\b"
    },
    "sql-keyword": {
      "name": "keyword.other.sql",
      "match": "(?i)\\b(SELECT|FROM|WHERE|AND|OR|NOT|NULL|INSERT|INTO|VALUES|UPDATE|SET|DELETE|EXECUTE|DECLARE|CURSOR|FOR|OPEN|FETCH|CLOSE|PREPARE|DESCRIBE|COMMIT|ROLLBACK|WORK|CONNECT|DISCONNECT|CURRENT|SQL|WHENEVER|GOTO|CONTINUE|INCLUDE|INDICATOR|USING|BY|GROUP|ORDER|HAVING|UNION|ALL|DISTINCT|JOIN|LEFT|RIGHT|INNER|OUTER|ON|AS|CASE|WHEN|THEN|ELSE|END|BETWEEN|LIKE|IN|EXISTS|IS|AT|BEGIN|OF|ROWS|ONLY|WITH|READ|OPTIMIZE|ROW|LOCK|SHARE|SKIP|LOCKED|DATA|BUFFER|POOL|INDEX|TABLE|VIEW|SCHEMA|GRANT|REVOKE|REFERENCES|CONSTRAINT|PRIMARY|KEY|FOREIGN|DEFAULT|CHECK|CREATE|ALTER|DROP|TRIGGER|PROCEDURE|FUNCTION|CALL|RETURN|RETURNS|LANGUAGE|READS|WRITES|MODIFIES|STATIC|DYNAMIC|IMMEDIATE|HOST|VARIABLES|FIRST|NEXT|PRIOR|LAST|ABSOLUTE|RELATIVE|SENSITIVE|INSENSITIVE|SCROLL|HOLD|WITHOUT|RESULT|SETS|ATOMIC|SAVEPOINT|RELEASE|TO)\\b"
    },
    "host-variable": {
      "name": "variable.other.host.sql",
      "match": ":[A-Za-z0-9][A-Za-z0-9_-]*"
    },
    "sql-comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sql",
          "match": "--[^\\n]*"
        },
        {
          "name": "comment.block.sql",
          "match": "/\\*[\\s\\S]*?\\*/"
        }
      ]
    },
    "exec-sql-inner": {
      "patterns": [
        { "include": "#sql-comment" },
        { "include": "#string-single" },
        { "include": "#string-double" },
        { "include": "#host-variable" },
        { "include": "#cobol-numeric-literal" },
        { "include": "#sql-function" },
        { "include": "#sql-keyword" }
      ]
    },
    "exec-sql-block": {
      "contentName": "meta.embedded.block.sql.cobol",
      "begin": "(?i)(\\bEXEC\\s+SQL\\b)",
      "beginCaptures": {
        "1": { "name": "keyword.other.exec-sql.begin.cobol" }
      },
      "end": "(?i)(\\bEND-EXEC)(\\.)?",
      "endCaptures": {
        "1": { "name": "keyword.other.exec-sql.end.cobol" },
        "2": { "name": "punctuation.terminator.statement.cobol" }
      },
      "patterns": [{ "include": "#exec-sql-inner" }]
    }
  }
}
