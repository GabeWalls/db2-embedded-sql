{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DB2 COBOL (fallback)",
  "scopeName": "source.db2-cobol",
  "patterns": [
    { "include": "#exec-sql-block" },
    { "include": "#cobol-comment" },
    { "include": "#string-single" },
    { "include": "#string-double" },
    { "include": "#cobol-level-number" },
    { "include": "#cobol-keyword-fallback" },
    { "include": "#cobol-data-name" }
  ],
  "repository": {
    "cobol-comment": {
      "patterns": [
        {
          "name": "comment.line.cobol",
          "match": "(?m)^.{6}[/*][^\\n]*$"
        },
        {
          "name": "comment.line.cobol",
          "match": "(?m)^\\s*\\*>[^\\n]*$"
        }
      ]
    },
    "string-single": {
      "name": "string.quoted.single.cobol",
      "match": "(?m)'(?:''|[^'\\n])*'"
    },
    "string-double": {
      "name": "string.quoted.double.cobol",
      "match": "(?m)\"(?:\"\"|[^\"\\n])*\""
    },
    "cobol-level-number": {
      "patterns": [
        {
          "comment": "Fixed-format: cols 1-6 sequence/change, col 7 not * or /, then Area A/B spaces and level 01-49, 66, 77, 88 (not PIC 9(5) etc., which are not line-anchored this way).",
          "match": "(?m)^(?!\\s*\\*>)(?!.{6}[*/])(.{6})(.)(\\s*)(0[1-9]|[12][0-9]|3[0-9]|4[0-9]|66|77|88)(?=\\s)",
          "captures": {
            "4": { "name": "constant.numeric.level.cobol" }
          }
        }
      ]
    },
    "cobol-data-name": {
      "patterns": [
        {
          "comment": "Hyphenated COBOL data names; excludes common hyphenated reserved phrases.",
          "name": "variable.other.cobol",
          "match": "(?i)\\b(?!(?:WORKING-STORAGE|OBJECT-COMPUTER|PROGRAM-ID|LOCAL-STORAGE|FILE-SECTION|DATA-DIVISION|PROCEDURE-DIVISION|IDENTIFICATION-DIVISION|ENVIRONMENT-DIVISION|SCREEN-SECTION|LINKAGE-SECTION|INPUT-OUTPUT|FILE-CONTROL|END-IF|END-EXEC|END-EVALUATE|END-PERFORM|END-READ|END-WRITE|HIGH-VALUES|LOW-VALUES|LINE-COUNTER|PAGE-COUNTER|SOURCE-COMPUTER|SPECIAL-NAMES)\\b)([A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+)\\b"
        }
      ]
    },
    "cobol-keyword-fallback": {
      "name": "keyword.control.cobol",
      "match": "(?i)\\b(ACCEPT|ADD|ADDRESS|ADVANCING|AFTER|ALL|AND|ALTER|ASSIGN|AUTHOR|BINARY|BLANK|BLOCK|BY|CALL|CANCEL|CLASS|CLOSE|CODE|COLUMN|CONFIGURATION|CONTINUE|COPY|DATA|DATE|DAY|DELETE|DISPLAY|DIVISION|DIVIDE|ELSE|END|END-EVALUATE|END-IF|END-PERFORM|END-READ|END-WRITE|ENTRY|ENVIRONMENT|EVALUATE|EXECUTE|EXIT|FD|FILE|FILLER|FOR|FROM|FUNCTION|GIVING|GLOBAL|GO|GOBACK|GREATER|GROUP|HEADING|HIGH-VALUE|HIGH-VALUES|IDENTIFICATION|IF|IN|INDEX|INITIALIZE|INPUT|INSPECT|INSTALLATION|INTO|INVALID|IS|JUSTIFIED|KEY|LABEL|LESS|LINKAGE|LOCAL-STORAGE|LOCK|LOW-VALUE|LOW-VALUES|MEMORY|MERGE|MOVE|MULTIPLY|NOT|NULL|NUMBER|OBJECT-COMPUTER|OCCURS|OF|OFF|ON|OPEN|OPTIONAL|OR|ORGANIZATION|OTHER|OUTPUT|OVERFLOW|PERFORM|PIC|PICTURE|PLUS|POINTER|POSITION|PROCEDURE|PROGRAM|PROGRAM-ID|PURGE|READ|RECORD|REDEFINES|RELEASE|RENAMES|REPLACE|REPORT|RETURN|REWRITE|RUN|SEARCH|SECTION|SELECT|SEND|SEQUENTIAL|SET|SIGN|SORT|SOURCE|SPACE|SPACES|STANDARD|STOP|STRING|SUBTRACT|SUM|THAN|THROUGH|THRU|TIMES|TO|TRUE|UNTIL|USAGE|USE|USING|VALUE|VALUES|WHEN|WITH|WORKING-STORAGE|WRITE|ZERO|ZEROS)\\b"
    },
    "sql-current": {
      "name": "keyword.other.sql",
      "match": "(?i)\\bCURRENT\\s+(?:DATE|TIME|TIMESTAMP|USER)\\b"
    },
    "sql-numeric-literal": {
      "name": "constant.numeric.sql",
      "match": "(?i)(?<![A-Za-z0-9_:])(?:\\d+\\.\\d+|\\.\\d+|\\d+)(?![A-Za-z0-9_:])"
    },
    "sql-support-function": {
      "name": "support.function.sql",
      "match": "(?i)\\b(?:COUNT|SUM|AVG|MIN|MAX|COALESCE|NULLIF|CHAR|VARCHAR|DECIMAL|INTEGER|DATE|TIME|TIMESTAMP|SUBSTR|LENGTH|TRIM|UPPER|LOWER)\\b"
    },
    "sql-keyword": {
      "name": "keyword.other.sql",
      "match": "(?i)\\b(?:SELECT|INSERT|UPDATE|DELETE|MERGE|INTO|FROM|WHERE|SET|VALUES|JOIN|INNER|LEFT|RIGHT|FULL|OUTER|CROSS|ON|GROUP|BY|ORDER|HAVING|FETCH|FIRST|ONLY|ROW|ROWS|DECLARE|CURSOR|FOR|OPEN|CLOSE|PREPARE|EXECUTE|IMMEDIATE|COMMIT|ROLLBACK|WORK|CONNECT|DISCONNECT|WHENEVER|SQLERROR|SQLWARNING|FOUND|CONTINUE|INCLUDE|SQLCA|SQLDA|WITH|AS|UNION|ALL|DISTINCT|CASE|WHEN|THEN|ELSE|END|EXISTS|IN|BETWEEN|LIKE|IS|NULL|NOT|AND|OR|AT|BEGIN|OF|READ|OPTIMIZE|LOCK|SHARE|SKIP|LOCKED|DATA|BUFFER|POOL|INDEX|TABLE|VIEW|SCHEMA|GRANT|REVOKE|REFERENCES|CONSTRAINT|PRIMARY|KEY|FOREIGN|DEFAULT|CHECK|CREATE|ALTER|DROP|TRIGGER|PROCEDURE|FUNCTION|CALL|RETURN|RETURNS|LANGUAGE|READS|WRITES|MODIFIES|STATIC|DYNAMIC|HOST|VARIABLES|NEXT|PRIOR|LAST|ABSOLUTE|RELATIVE|SENSITIVE|INSENSITIVE|SCROLL|HOLD|WITHOUT|RESULT|SETS|ATOMIC|SAVEPOINT|RELEASE|TO|DESCRIBE|INDICATOR|USING|GO\\s+TO|GOTO)\\b"
    },
    "host-variable": {
      "name": "variable.other.host.sql",
      "match": ":[A-Za-z0-9][A-Za-z0-9_-]*"
    },
    "sql-comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sql",
          "match": "--[^\\n]*"
        },
        {
          "name": "comment.block.sql",
          "match": "/\\*[\\s\\S]*?\\*/"
        }
      ]
    },
    "exec-sql-inner": {
      "patterns": [
        { "include": "#sql-comment" },
        { "include": "#string-single" },
        { "include": "#string-double" },
        { "include": "#sql-current" },
        { "include": "#sql-numeric-literal" },
        { "include": "#host-variable" },
        { "include": "#sql-support-function" },
        { "include": "#sql-keyword" }
      ]
    },
    "exec-sql-block": {
      "contentName": "meta.embedded.block.sql.cobol",
      "begin": "(?i)(\\bEXEC\\s+SQL\\b)",
      "beginCaptures": {
        "1": { "name": "keyword.other.exec-sql.begin.cobol" }
      },
      "end": "(?i)(\\bEND-EXEC)(\\.)?",
      "endCaptures": {
        "1": { "name": "keyword.other.exec-sql.end.cobol" },
        "2": { "name": "punctuation.terminator.statement.cobol" }
      },
      "patterns": [{ "include": "#exec-sql-inner" }]
    }
  }
}
