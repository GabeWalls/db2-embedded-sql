{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DB2 COBOL",
  "scopeName": "source.db2-cobol",
  "patterns": [
    { "include": "#exec-sql-block" },
    { "include": "#cobol-comment" },
    { "include": "#string-single" },
    { "include": "#string-double" },
    { "include": "#cobol-keyword" }
  ],
  "repository": {
    "cobol-comment": {
      "patterns": [
        {
          "name": "comment.line.cobol",
          "match": "^.{6}\\*.*$"
        },
        {
          "name": "comment.line.cobol",
          "match": "^\\s*\\*>.*$"
        }
      ]
    },
    "string-single": {
      "name": "string.quoted.single.cobol",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.cobol",
          "match": "''"
        }
      ]
    },
    "string-double": {
      "name": "string.quoted.double.cobol",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.cobol",
          "match": "\"\""
        }
      ]
    },
    "cobol-keyword": {
      "name": "keyword.control.cobol",
      "match": "(?i)\\b(ACCEPT|ADD|ADDRESS|ADVANCING|AFTER|ALL|ALPHABET|ALPHABETIC|ALPHABETIC-LOWER|ALPHABETIC-UPPER|ALPHANUMERIC|ALPHANUMERIC-EDITED|ALSO|ALTER|ALTERNATE|AND|ANY|ARE|AREA|AREAS|ASCENDING|ASSIGN|AT|AUTHOR|BEFORE|BINARY|BLANK|BLOCK|BOTTOM|BY|CALL|CANCEL|CBL|CD|CF|CH|CHARACTER|CHARACTERS|CLASS|CLOSE|CODE|CODE-SET|COLLATING|COLUMN|COMMA|COMMON|COMMUNICATION|COMP|COMP-1|COMP-2|COMP-3|COMP-4|COMP-5|COMPUTATIONAL|COMPUTATIONAL-1|COMPUTATIONAL-2|COMPUTATIONAL-3|COMPUTE|CONFIGURATION|CONTENT|CONTINUE|CONTROL|CONTROLS|CONVERTING|COPY|CORR|CORRESPONDING|COUNT|CURRENCY|DATA|DATE|DATE-COMPILED|DAY|DAY-OF-WEEK|DBCS|DE|DEBUG-CONTENTS|DEBUG-ITEM|DEBUG-LINE|DEBUG-NAME|DEBUG-SUB-1|DEBUG-SUB-2|DEBUG-SUB-3|DEBUGGING|DECIMAL-POINT|DECLARATIVES|DELETE|DELIMITED|DELIMITER|DEPENDING|DESCENDING|DESTINATION|DETAIL|DISPLAY|DIVIDE|DIVISION|DOWN|DUPLICATES|DYNAMIC|EGI|EJECT|ELSE|EMI|ENABLE|END|END-ADD|END-CALL|END-COMPUTE|END-DELETE|END-DIVIDE|END-EVALUATE|END-IF|END-MULTIPLY|END-OF-PAGE|END-PERFORM|END-READ|END-RECEIVE|END-RETURN|END-REWRITE|END-SEARCH|END-START|END-STRING|END-SUBTRACT|END-UNSTRING|END-WRITE|ENTER|ENTRY|ENVIRONMENT|EOP|EQUAL|ERROR|ESI|EVALUATE|EVERY|EXCEPTION|EXIT|EXTEND|EXTERNAL|FALSE|FD|FILE|FILE-CONTROL|FILLER|FINAL|FIRST|FOOTING|FOR|FROM|FUNCTION|GENERATE|GIVING|GLOBAL|GO|GOBACK|GREATER|GROUP|HEADING|HIGH-VALUE|HIGH-VALUES|I-O|I-O-CONTROL|IDENTIFICATION|IF|IN|INDEX|INDEXED|INDICATE|INITIAL|INITIALIZE|INITIATE|INPUT|INPUT-OUTPUT|INSPECT|INSTALLATION|INTO|INVALID|IS|JUST|JUSTIFIED|KEY|LABEL|LAST|LEADING|LEFT|LENGTH|LESS|LIMIT|LIMITS|LINAGE|LINAGE-COUNTER|LINE|LINE-COUNTER|LINES|LINKAGE|LOCAL|LOCAL-STORAGE|LOCK|LOW-VALUE|LOW-VALUES|MEMORY|MERGE|MESSAGE|MODE|MODULES|MOVE|MULTIPLE|MULTIPLY|NATIVE|NEGATIVE|NEXT|NO|NOT|NULL|NULLS|NUMBER|NUMERIC|NUMERIC-EDITED|OBJECT-COMPUTER|OCCURS|OF|OFF|OMITTED|ON|OPEN|OPTIONAL|OR|ORDER|ORGANIZATION|OTHER|OUTPUT|OVERFLOW|OWN|PACKED-DECIMAL|PADDING|PAGE|PAGE-COUNTER|PERFORM|PF|PH|PIC|PICTURE|PLUS|POINTER|POSITION|POSITIVE|PRINTING|PROCEDURE|PROCEDURES|PROCEED|PROGRAM|PROGRAM-ID|PURGE|QUEUE|QUOTE|QUOTES|RANDOM|RD|READ|RECEIVE|RECORD|RECORDING|RECORDS|REDEFINES|REEL|REFERENCE|REFERENCES|RELATIVE|RELEASE|REMAINDER|REMOVAL|RENAMES|REPLACE|REPLACING|REPORT|REPORTING|REPORTS|RERUN|RESERVE|RESET|RETURN|RETURNING|REVERSED|REWIND|REWRITE|RF|RH|RIGHT|ROUNDED|RUN|SAME|SD|SEARCH|SECTION|SECURITY|SEGMENT|SEGMENT-LIMIT|SELECT|SEND|SENTENCE|SEPARATE|SEQUENCE|SEQUENTIAL|SET|SIGN|SIZE|SORT|SORT-MERGE|SOURCE|SOURCE-COMPUTER|SPACE|SPACES|SPECIAL-NAMES|STANDARD|STANDARD-1|STANDARD-2|START|STATUS|STOP|STRING|SUB-QUEUE-1|SUB-QUEUE-2|SUB-QUEUE-3|SUBTRACT|SUM|SUPPRESS|SYMBOLIC|SYNC|SYNCHRONIZED|TABLE|TALLYING|TAPE|TERMINAL|TERMINATE|TEST|THAN|THROUGH|THRU|TIME|TIMES|TO|TOP|TRAILING|TRUE|TYPE|UNIT|UNSTRING|UNTIL|UP|UPON|USAGE|USE|USING|VALUE|VALUES|VARYING|WHEN|WITH|WORDS|WORKING-STORAGE|WRITE|ZERO|ZEROES|ZEROS)\\b"
    },
    "sql-keyword": {
      "name": "keyword.other.sql",
      "match": "(?i)\\b(SELECT|FROM|WHERE|AND|OR|NOT|NULL|INSERT|INTO|VALUES|UPDATE|SET|DELETE|EXECUTE|DECLARE|CURSOR|FOR|OPEN|FETCH|CLOSE|PREPARE|DESCRIBE|COMMIT|ROLLBACK|WORK|CONNECT|DISCONNECT|SET|CURRENT|SQL|WHENEVER|GOTO|CONTINUE|INCLUDE|INDICATOR|INTO|USING|FROM|TO|BY|GROUP|ORDER|HAVING|UNION|ALL|DISTINCT|JOIN|LEFT|RIGHT|INNER|OUTER|ON|AS|CASE|WHEN|THEN|ELSE|END|BETWEEN|LIKE|IN|EXISTS|IS|AT|BEGIN|END|OF|ROWS|ONLY|WITH|READ|ONLY|OPTIMIZE|FOR|ROW|LOCK|SHARE|UPDATE|SKIP|LOCKED|DATA|BUFFER|POOL|INDEX|TABLE|VIEW|SCHEMA|GRANT|REVOKE|REFERENCES|CONSTRAINT|PRIMARY|KEY|FOREIGN|DEFAULT|CHECK|CREATE|ALTER|DROP|TRIGGER|PROCEDURE|FUNCTION|CALL|RETURN|RETURNS|LANGUAGE|READS|WRITES|MODIFIES|STATIC|DYNAMIC|IMMEDIATE|HOST|VARIABLES|ROWS|FETCH|FIRST|NEXT|PRIOR|LAST|ABSOLUTE|RELATIVE|SENSITIVE|INSENSITIVE|SCROLL|WITH|HOLD|WITHOUT|RETURN|RESULT|SETS|ATOMIC|SAVEPOINT|RELEASE)\\b"
    },
    "host-variable": {
      "name": "variable.other.host.sql",
      "match": ":[A-Za-z0-9][A-Za-z0-9_-]*"
    },
    "sql-comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sql",
          "match": "--[^\\n]*"
        },
        {
          "name": "comment.block.sql",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "exec-sql-inner": {
      "patterns": [
        { "include": "#sql-comment" },
        { "include": "#string-single" },
        { "include": "#string-double" },
        { "include": "#host-variable" },
        { "include": "#sql-keyword" }
      ]
    },
    "exec-sql-block": {
      "name": "meta.embedded.sql.cobol",
      "begin": "(?i)(\\bEXEC\\s+SQL\\b)",
      "beginCaptures": {
        "1": { "name": "keyword.other.exec.sql.cobol" }
      },
      "end": "(?i)\\b(END-EXEC)\\b",
      "endCaptures": {
        "1": { "name": "keyword.other.exec.sql.cobol" }
      },
      "patterns": [
        { "include": "#exec-sql-inner" }
      ]
    }
  }
}
